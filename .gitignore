# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Uploaded files
public/uploads/

# Crawled / Large Data Folders
public/gentop/*.html
public/gentop/*_files/
public/gentop/*.py
public/gentop/*.sh
public/gentop/EMT_files/
public/gentop/Contact_files/
public/gentop/information_files/
public/gentop/HS-TECH_files/
public/gentop/public/

# Generated PDF catalogs
public/report/*.pdf

# Air HS-TECH raw crawled source files (HTML + _files/ folders)
public/air_hstech/*.html
public/air_hstech/*_files/

# Expo mobile app
mobile/node_modules/
mobile/dist/
mobile/.expo/
mobile/app.app/
mobile/build-*.tar.gz

# Database
prisma/*.db
prisma/*.db-journal

# Build logs
.turbo/
