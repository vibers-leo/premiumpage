// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application Models
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  components  String   // JSON string
  thumbnail   String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// 계발자들 매거진 — 프로젝트 자기소개 포스트
model VibersPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  projectName String
  tagline     String
  projectUrl  String?

  // 공통 질문 답변
  whatIsIt    String
  whyBuilt    String
  keyFeature  String
  techStack   String
  proudOf     String
  challenge   String?

  // 메타
  category    String   @default("dev")
  coverImage  String?
  publishedAt DateTime @default(now())
  issueId     String   @default("2026-03")
}

model QuoteRequest {
  id              String   @id @default(cuid())
  templateId      String
  developmentPlanId String?
  maintenancePlanId String?
  companyName     String?
  businessName    String?
  businessType    String?
  contactName     String
  contactEmail    String
  contactPhone    String
  projectDetails  String?
  requirements    String?
  budget          String?
  timeline        String?
  additionalNotes String?
  attachments     String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
