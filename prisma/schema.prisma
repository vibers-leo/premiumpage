generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "premiumpage"]
}

// ── premiumpage SaaS 모델 ──────────────────────────────

model PmCustomer {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  companyName  String?  @map("company_name")
  contactName  String?  @map("contact_name")
  phone        String?
  planType     String   @default("free") @map("plan_type")
  memo         String?
  createdAt    DateTime @default(now()) @map("created_at")

  orders           PmOrder[]
  customerCatalogs PmCustomerCatalog[]
  requests         PmRequest[]

  @@map("customers")
  @@schema("premiumpage")
}

model PmCatalog {
  id           String   @id
  name         String
  description  String?
  thumbnailUrl String?  @map("thumbnail_url")
  baseUrl      String?  @map("base_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  versions         PmCatalogVersion[]
  orders           PmOrder[]
  customerCatalogs PmCustomerCatalog[]

  @@map("catalogs")
  @@schema("premiumpage")
}

model PmCatalogVersion {
  id          String   @id @default(uuid())
  catalogId   String   @map("catalog_id")
  version     String
  url         String
  changeNotes String?  @map("change_notes")
  isCurrent   Boolean  @default(false) @map("is_current")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  catalog PmCatalog @relation(fields: [catalogId], references: [id])

  @@map("catalog_versions")
  @@schema("premiumpage")
}

model PmOrder {
  id              String    @id
  customerId      String?   @map("customer_id")
  catalogId       String?   @map("catalog_id")
  amount          Int
  status          String    @default("pending")
  tossPaymentKey  String?   @map("toss_payment_key")
  tossOrderId     String?   @unique @map("toss_order_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  paidAt          DateTime? @map("paid_at")

  customer         PmCustomer?         @relation(fields: [customerId], references: [id])
  catalog          PmCatalog?          @relation(fields: [catalogId], references: [id])
  customerCatalogs PmCustomerCatalog[]

  @@map("orders")
  @@schema("premiumpage")
}

model PmCustomerCatalog {
  id         String    @id @default(uuid())
  customerId String    @map("customer_id")
  catalogId  String    @map("catalog_id")
  orderId    String?   @map("order_id")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer PmCustomer @relation(fields: [customerId], references: [id])
  catalog  PmCatalog  @relation(fields: [catalogId], references: [id])
  order    PmOrder?   @relation(fields: [orderId], references: [id])

  @@map("customer_catalogs")
  @@schema("premiumpage")
}

model PmPaymentLink {
  id            String    @id @default(uuid())
  token         String    @unique @default(uuid())
  amount        Int
  orderName     String    @map("order_name")
  customerName  String?   @map("customer_name")
  customerEmail String?   @map("customer_email")
  memo          String?
  status        String    @default("pending")   // pending | paid | expired
  tossOrderId   String?   @unique @map("toss_order_id")
  tossPaymentKey String?  @map("toss_payment_key")
  paidAt        DateTime? @map("paid_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("payment_links")
  @@schema("premiumpage")
}

model PmRequest {
  id           String   @id @default(uuid())
  customerId   String?  @map("customer_id")
  title        String
  description  String?
  referenceUrl String?  @map("reference_url")
  status       String   @default("received")
  adminNote    String?  @map("admin_note")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  customer PmCustomer? @relation(fields: [customerId], references: [id])

  @@map("requests")
  @@schema("premiumpage")
}

model QuoteRequest {
  id               String   @id
  quoteNumber      String   @unique @map("quote_number")
  templateId       String?  @map("template_id")
  developmentPlanId String? @map("development_plan_id")
  maintenancePlanId String? @map("maintenance_plan_id")
  proposalPlanId   String?  @map("proposal_plan_id")
  serviceType      String?  @map("service_type")
  companyName      String?  @map("company_name")
  contactName      String   @map("contact_name")
  contactEmail     String   @map("contact_email")
  contactPhone     String   @map("contact_phone")
  projectDetails   String?  @map("project_details")
  attachments      String?
  status           String   @default("pending")
  adminNote        String?  @map("admin_note")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("quote_requests")
  @@schema("premiumpage")
}
