generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "premiumpage"]
}

// ══════════════════════════════════════════════
// 사용자 & 인증
// ══════════════════════════════════════════════

model PmUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  phone         String?
  companyName   String?   @map("company_name")
  avatarUrl     String?   @map("avatar_url")
  role          String    @default("client") // client | admin
  isActive      Boolean   @default(true) @map("is_active")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")

  socialAccounts PmSocialAccount[]
  orders         PmOrder[]
  orderComments  PmOrderComment[]
  creditTxns     PmCreditTransaction[]

  @@map("users")
  @@schema("premiumpage")
}

model PmSocialAccount {
  id         String @id @default(uuid())
  userId     String @map("user_id")
  provider   String // google | naver | kakao
  providerId String @map("provider_id")

  user PmUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("social_accounts")
  @@schema("premiumpage")
}

// ══════════════════════════════════════════════
// 상품 (서비스 카탈로그)
// ══════════════════════════════════════════════

model PmProduct {
  id           String  @id @default(uuid())
  slug         String  @unique
  name         String
  category     String  // catalog | leaflet | proposal | maintenance
  description  String?
  priceRange   String? @map("price_range")
  price        Int?
  durationDays Int?    @map("duration_days")
  isActive     Boolean @default(true) @map("is_active")
  sortOrder    Int     @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  orders PmOrder[]

  @@map("products")
  @@schema("premiumpage")
}

// ══════════════════════════════════════════════
// 주문 & 진행 관리
// ══════════════════════════════════════════════

model PmOrder {
  id             String    @id @default(uuid())
  orderNumber    String    @unique @map("order_number")
  userId         String    @map("user_id")
  productId      String?   @map("product_id")
  title          String
  description    String?
  amount         Int       @default(0)
  status         String    @default("pending")
  // pending → accepted → in_progress → review → revision → completed → cancelled

  // 결제
  tossPaymentKey String?   @map("toss_payment_key")
  tossOrderId    String?   @unique @map("toss_order_id")
  paidAt         DateTime? @map("paid_at")

  // 진행 일정
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  deadline       DateTime?

  // 첨부/참조
  attachments    String?   // JSON array of file URLs
  referenceUrl   String?   @map("reference_url")
  adminNote      String?   @map("admin_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user     PmUser          @relation(fields: [userId], references: [id])
  product  PmProduct?      @relation(fields: [productId], references: [id])
  comments PmOrderComment[]

  @@index([userId])
  @@index([status])
  @@map("orders")
  @@schema("premiumpage")
}

model PmOrderComment {
  id            String  @id @default(uuid())
  orderId       String  @map("order_id")
  userId        String  @map("user_id")
  content       String
  attachmentUrl String? @map("attachment_url")
  isInternal    Boolean @default(false) @map("is_internal") // 어드민 내부 메모
  createdAt     DateTime @default(now()) @map("created_at")

  order PmOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  PmUser  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@map("order_comments")
  @@schema("premiumpage")
}

// ══════════════════════════════════════════════
// 크레딧 & 결제 이력
// ══════════════════════════════════════════════

model PmCreditTransaction {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String   // earn | spend | refund
  amount       Int
  balanceAfter Int      @map("balance_after")
  description  String?
  referenceId  String?  @map("reference_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user PmUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("credit_transactions")
  @@schema("premiumpage")
}

// ══════════════════════════════════════════════
// 견적 요청 (기존 유지)
// ══════════════════════════════════════════════

model QuoteRequest {
  id                String   @id
  quoteNumber       String   @unique @map("quote_number")
  templateId        String?  @map("template_id")
  developmentPlanId String?  @map("development_plan_id")
  maintenancePlanId String?  @map("maintenance_plan_id")
  proposalPlanId    String?  @map("proposal_plan_id")
  serviceType       String?  @map("service_type")
  companyName       String?  @map("company_name")
  contactName       String   @map("contact_name")
  contactEmail      String   @map("contact_email")
  contactPhone      String   @map("contact_phone")
  projectDetails    String?  @map("project_details")
  attachments       String?
  status            String   @default("pending")
  adminNote         String?  @map("admin_note")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("quote_requests")
  @@schema("premiumpage")
}

// ══════════════════════════════════════════════
// 결제 링크 (기존 유지)
// ══════════════════════════════════════════════

model PmPaymentLink {
  id             String    @id @default(uuid())
  token          String    @unique @default(uuid())
  amount         Int
  orderName      String    @map("order_name")
  customerName   String?   @map("customer_name")
  customerEmail  String?   @map("customer_email")
  memo           String?
  status         String    @default("pending")
  tossOrderId    String?   @unique @map("toss_order_id")
  tossPaymentKey String?   @map("toss_payment_key")
  paidAt         DateTime? @map("paid_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("payment_links")
  @@schema("premiumpage")
}
