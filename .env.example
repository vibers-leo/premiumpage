# Database (NCP PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5433/vibers_main

# Portal JWT
JWT_SECRET=change-me-in-production

# OAuth — Google (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Naver (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth — Kakao (https://developers.kakao.com)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 토스페이먼츠
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# SMTP (이메일 발송)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 관리자
ADMIN_EMAIL=

# 앱 URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# NCP Object Storage (파일 첨부)
NCP_ACCESS_KEY=
NCP_SECRET_KEY=
NCP_BUCKET_NAME=

# Firebase (레거시)
NEXT_PUBLIC_FIREBASE_API_KEY=
