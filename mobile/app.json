{
  "expo": {
    "name": "프리미엄페이지",
    "slug": "vibers-premiumpage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "premiumpage",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibers.premiumpage"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vibers.premiumpage"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "./plugins/withXcode26Fix"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f80059a9-b35d-4840-87c9-522eb9d9c14b"
      }
    },
    "owner": "juuuno1116"
  }
}